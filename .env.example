# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git

# GoHighLevel webhook URL (from GHL subaccount → Settings → Integrations → Webhooks)
NEXT_PUBLIC_GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_WEBHOOK_ID_HERE

# Site URL (for canonical links and OG metadata)
NEXT_PUBLIC_SITE_URL=https://enroll.campnac.com

# Enrollment close date (format: YYYY-MM-DD)
# Countdown timer in UrgencyBanner uses this date
NEXT_PUBLIC_ENROLLMENT_CLOSE_DATE=2026-07-31
